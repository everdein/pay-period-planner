{
  "name": "end-to-end-app",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "prepare": "husky",
    "build": "npm run build:frontend",
    "build:frontend": "npm --prefix frontend run build",
    "test": "npm run test:frontend",
    "test:frontend": "npm --prefix frontend run test",
    "verify": "npm run lint && npm run build && npm run test",
    "format": "prettier --write .",
    "lint": "npm run code-quality",
    "code-quality": "npm --prefix frontend run lint",
    "code-quality:fix": "npm --prefix frontend run lint:fix",
    "spell": "cspell \"**/*.{md,ts,tsx,js,jsx,json,css,yml,yaml}\" \".agents/**/*.md\" \".codex/**/*.{md,toml}\""
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "npm run code-quality:fix",
      "prettier --write",
      "npx cspell --config .cspell.json"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write",
      "npx cspell --config .cspell.json"
    ]
  },
  "devDependencies": {
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4"
  }
}
