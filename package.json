{
  "name": "end-to-end-app",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "lint": "npm run code-quality",
    "code-quality": "npm --prefix frontend run lint",
    "code-quality:fix": "npm --prefix frontend run lint:fix",
    "spell": "cspell \"**/*.{md,ts,tsx,js,jsx,json,css,yml,yaml}\""
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "npm run code-quality:fix",
      "prettier --write",
      "npx cspell --config .cspell.json"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write",
      "npx cspell --config .cspell.json"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "cspell": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.6.2"
  }
}
